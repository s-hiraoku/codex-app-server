NODE_ENV=development
PORT=8787
HOST=127.0.0.1

DATABASE_PATH=./data/codex-app-server.sqlite

APP_BACKEND=codex-app-server
CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_TURN_TIMEOUT_MS=600000

# token hash pepper. Use a long random value in real deployments.
TOKEN_PEPPER=change-me-to-a-long-random-secret

# Temporary value for creating the first admin token. Remove after bootstrap.
# Refused in production; use only for local bootstrap, then delete it.
BOOTSTRAP_ADMIN_TOKEN=
